{
  "name": "testrail-mcp",
  "version": "1.0.0",
  "description": "MCP server for TestRail REST API — manage projects, suites, cases, runs, results, and more from Claude Desktop",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "testrail",
    "testing",
    "model-context-protocol",
    "claude",
    "test-management"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "testrail-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
