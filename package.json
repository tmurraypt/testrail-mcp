{
  "name": "testrail-mcp",
  "version": "1.0.0",
  "description": "MCP server for TestRail REST API — manage projects, suites, cases, runs, results, and more from Claude Desktop",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "testrail",
    "testing",
    "model-context-protocol",
    "claude",
    "test-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmurraypt/testrail-mcp.git"
  },
  "homepage": "https://github.com/tmurraypt/testrail-mcp#readme",
  "bugs": {
    "url": "https://github.com/tmurraypt/testrail-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "testrail-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js"
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "zod": "^3.25.0"
  }
}
